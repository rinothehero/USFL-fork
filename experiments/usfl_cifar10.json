{
  "method": "usfl",
  "dataset": "cifar10",
  "model": "resnet18",
  "split_layer": "layer2",
  "rounds": 100,
  "num_clients": 100,
  "clients_per_round": 10,
  "local_epochs": 5,
  "batch_size": 50,
  "learning_rate": 0.001,
  "momentum": 0.9,
  "weight_decay": 0.0,
  "optimizer": "sgd",
  "distribution": "shard_dirichlet",
  "alpha": 0.3,
  "labels_per_client": 2,
  "selector": "usfl",
  "aggregator": "usfl",
  "gradient_shuffle": true,
  "gradient_shuffle_strategy": "random",
  "balancing_strategy": "target",
  "balancing_target": "mean",
  "use_dynamic_batch_scheduler": true,
  "use_cumulative_usage": false,
  "use_fresh_scoring": false,
  "server_training_mode": "concatenated_fused",
  "device": "cuda",
  "seed": 42
}
