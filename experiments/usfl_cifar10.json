{
  "method": "usfl",
  "dataset": "cifar10",
  "_dataset_options": "cifar10 | cifar100 | fmnist | mnist | svhn",
  "model": "resnet18",
  "_model_options": "resnet18 | vgg11 | alexnet | mobilenetv2 | lenet5 | deit_tiny",
  "split_layer": "layer2",
  "rounds": 100,
  "num_clients": 100,
  "clients_per_round": 10,
  "local_epochs": 5,
  "batch_size": 50,
  "learning_rate": 0.001,
  "momentum": 0.0,
  "weight_decay": 0.0,
  "optimizer": "sgd",
  "_optimizer_options": "sgd | adam | adamw",
  "distribution": "shard_dirichlet",
  "_distribution_options": "uniform | dirichlet | shard_dirichlet",
  "alpha": 0.3,
  "labels_per_client": 2,
  "selector": "uniform",
  "_selector_options": "uniform | usfl",
  "aggregator": "fedavg",
  "_aggregator_options": "fedavg | usfl",
  "exhaustion_policy": "skip",
  "_exhaustion_policy_options": "cycling | skip | break | dbs",
  "device": "cuda",
  "_device_options": "cuda | cpu",
  "seed": 42,

  "_opt1": "=== Optimization 1: Data Balancing ===",
  "balancing_strategy": "none",
  "_balancing_strategy_options": "none | trimming | replication | target",
  "balancing_target": "mean",
  "_balancing_target_options": "mean | median | <integer>",

  "_opt2": "=== Optimization 2: Gradient Shuffle ===",
  "gradient_shuffle": true,
  "gradient_shuffle_strategy": "random",
  "_gradient_shuffle_strategy_options": "random | inplace | average | average_adaptive_alpha",

  "_opt3": "=== Optimization 3: Dynamic Batch Scheduler ===",
  "use_dynamic_batch_scheduler": false,

  "_opt4": "=== Optimization 4: Client Gradient Scaling ===",
  "scale_client_grad": false,

  "server_training_mode": "concatenated_fused",
  "_server_training_mode_options": "concatenated | concatenated_fused",

  "_note": "All optimizations off + selector=uniform + aggregator=fedavg = SFL-equivalent"
}
